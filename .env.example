# Linear Integration Configuration
# ป้อน Personal API Token ของคุณที่นี่ (e.g. lin_api_...)
LINEAR_API_TOKEN=your_linear_api_token_here
GEMINI_API_KEY=your_gemini_api_key_here

# Site Configuration (NUH, TMH, or SBH)
CURRENT_SITE=NUH

# Optional: Path to specific Excel file (e.g. /path/to/TCM_HIS_Cortex_v1.0.0.xlsx)
# If not specified, the script will auto-discover the file based on CURRENT_SITE
TARGET_EXCEL=

host = postgres-southeast-asia-non-prod.cortexcloud.co
db = dev_cortex
user = hlab-readonly
password = your_db_password_here
